local function performRespawnCleanup()
    if not States.fpsBoost then
        return
    end
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    pcall(function()
        local remotes = {
            ReplicatedStorage.Remotes:FindFirstChild("Replicate"),
            ReplicatedStorage.Remotes:FindFirstChild("Replicator"),
            ReplicatedStorage.ReiNew:FindFirstChild("DamageShower"),
            ReplicatedStorage.ReiNew:FindFirstChild("VFXReplicate")
        }
        for _, remote in ipairs(remotes) do
            if remote and remote:IsA("RemoteEvent") then
                remote:Destroy()
            end
        end
    end)
    pcall(function()
        local targets = {
            game:GetService("StarterPlayer").StarterPlayerScripts:FindFirstChild("Replicator"),
            game:GetService("StarterPlayer").StarterPlayerScripts:FindFirstChild("VFXReplicator"),
            LocalPlayer.PlayerScripts:FindFirstChild("Replicator"),
            LocalPlayer.PlayerScripts:FindFirstChild("VFXReplicator")
        }
        for _, obj in ipairs(targets) do
            if obj then
                obj.Disabled = true
                obj:Destroy()
            end
        end
    end)
    pcall(function()
        local madaraVFX = ReplicatedStorage.VFX:FindFirstChild("Madara")
        if madaraVFX and madaraVFX:FindFirstChild("SusRigged") then
            madaraVFX.SusRigged:Destroy()
        end
    end)
    pcall(function()
        local function wipe(folder)
            if not folder then
                return
            end
            local scripts = folder:FindFirstChild("Scripts")
            local modules = scripts and scripts:FindFirstChild("NewModules")
            if modules then
                if modules:FindFirstChild("ClientRemotes") then
                    modules.ClientRemotes:Destroy()
                end
                if modules:FindFirstChild("Hit") then
                    modules.Hit:Destroy()
                end
            end
        end
        wipe(LocalPlayer:FindFirstChild("Backpack"))
        wipe(game:GetService("StarterPack"))
    end)
end
