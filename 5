local function getClosestLiveEnemy()
    local character = getCharacter()
    local root = getHumanoidRoot(character)
    if not root then
        return
    end
    local closest, minDistance = nil, math.huge
    for _, model in ipairs(LiveFolder:GetChildren()) do
        if model:IsA('Model') and model ~= character then
            local targetRoot = getHumanoidRoot(model)
            local targetHumanoid = getHumanoid(model)
            if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                local distance = (root.Position - targetRoot.Position).Magnitude
                if distance < minDistance then
                    minDistance = distance
                    closest = model
                end
            end
        end
    end
    return closest
end
local function selectTargetByName(name)
    if name and name ~= '' and name ~= 'Any' then
        for _, model in ipairs(LiveFolder:GetChildren()) do
            if model:IsA('Model') and model ~= LocalPlayer.Character then
                if model.Name:find(name) then
                    local targetHumanoid = getHumanoid(model)
                    if targetHumanoid and targetHumanoid.Health > 0 then
                        return model
                    end
                end
            end
        end
        return nil
    end
    return getClosestLiveEnemy()
end
local function teleportToTarget(target, offsetDirection)
    local character = getCharacter()
    local root = getHumanoidRoot(character)
    local targetRoot = getHumanoidRoot(target)
    if root and targetRoot then
        root.CFrame = targetRoot.CFrame + offsetDirection
    end
end
local function autoEquipWeapon()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = getCharacter()
    if backpack and character then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local equipRemote = RemoteEvents:FindFirstChild("EquipWeaponRemote")
                if equipRemote then
                    safeFireRemote(equipRemote, "EquipWeaponRemote", false, tool.Name)
                end
                tool.Parent = character
                break
            end
        end
    end
end
