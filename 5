local function applyClip(enabled)
    if ClipConnection then
        ClipConnection:Disconnect()
        ClipConnection = nil
    end
    if enabled then
        ClipConnection = RunService.Stepped:Connect(function()
            local character = getCharacter()
            if character then
                for _, part in ipairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end
local function handleTarget(enemy)
    local targetRoot = getHumanoidRoot(enemy)
    local targetHumanoid = getHumanoid(enemy)
    if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
        local offsetDirection = DirectionOffsets[FarmState.angle] or DirectionOffsets.Above
        local offset = offsetDirection * FarmState.distance
        teleportToTarget(enemy, offset)
        autoEquipWeapon()
        local initialHealth = targetHumanoid.Health
        local attacking = true
        if FarmState.autoKillEnabled then
            task.spawn(function()
                while attacking and targetHumanoid and targetHumanoid.Health > 0 do
                    fireBladeCombat(false, targetRoot.Position, targetRoot.CFrame)
                    task.wait()
                end
            end)
            local startTime = tick()
            repeat
                task.wait()
            until targetHumanoid.Health < initialHealth or not FarmState.running or (tick() - startTime > 5)
            attacking = false
            if targetHumanoid and targetHumanoid.Health > 0 then
                targetHumanoid.Health = 0
                targetHumanoid:ChangeState(Enum.HumanoidStateType.Dead)
            end
        end
    end
end
local function farmLoop()
    task.spawn(function()
        while FarmState.running do
            local enemy = selectTargetByName(FarmState.targetName)
            if enemy then
                handleTarget(enemy)
                applyClip(FarmState.clipEnabled)
            end
            task.wait(0.01)
        end
        if not FarmState.running then
            applyClip(false)
        end
    end)
end
