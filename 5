local function getTowerNPC()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp or not workspace:FindFirstChild("Floors") then
        return
    end
    local best, dist = nil, math.huge
    for _, floor in ipairs(workspace.Floors:GetChildren()) do
        local npc = floor:FindFirstChild("NPC")
        if npc then
            local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildWhichIsA("BasePart")
            if root then
                local d = (root.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    best = npc
                end
            end
        end
    end
    return best
end
local AutoDungeonState = {
    active = false,
    range = 500,
}
local function runAutoDungeon()
    task.spawn(function()
        while AutoDungeonState.active do
            local character = getCharacter()
            local root = getHumanoidRoot(character)
            if root then
                local targetList = {}
                for _, model in ipairs(LiveFolder:GetChildren()) do
                    if model:IsA("Model") and model ~= character then
                        local tRoot = getHumanoidRoot(model)
                        local tHum = getHumanoid(model)
                        if tRoot and tHum and tHum.Health > 0 then
                            local dist = (root.Position - tRoot.Position).Magnitude
                            if dist <= AutoDungeonState.range then
                                table.insert(targetList, {model = model, root = tRoot, hum = tHum})
                            end
                        end
                    end
                end
                table.sort(targetList, function(a, b)
                    local distA = (root.Position - a.root.Position).Magnitude
                    local distB = (root.Position - b.root.Position).Magnitude
                    return distA < distB
                end)
                for _, data in ipairs(targetList) do
                    if not AutoDungeonState.active then
                        break
                    end
                    if data.hum and data.hum.Health > 0 then
                        root.CFrame = data.root.CFrame
                        repeat
                            task.wait()
                        until not data.hum or data.hum.Health <= 0 or not AutoDungeonState.active
                        task.wait(0.1)
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end
