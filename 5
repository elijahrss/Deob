local function updateEnemyDropdown()
    local seenNames = {}
    local options = {"Any"}
    for _, model in ipairs(LiveFolder:GetChildren()) do
        if model:IsA("Model") and model ~= LocalPlayer.Character then
            local rawName = model.Name
            local cleanName = rawName:gsub("%d+", ""):gsub("%s+$", "")
            if cleanName ~= "" and not cleanName:lower():find("dummy") then
                if not seenNames[cleanName] then
                    table.insert(options, cleanName)
                    seenNames[cleanName] = true
                end
            end
        end
    end
    table.sort(options)
    if enemyDropdown then
        enemyDropdown:Refresh(options, true)
    end
end
