DungeonTab:CreateToggle({
    Name = 'Auto Inf Tower',
    CurrentValue = false,
    Callback = function(value)
        DungeonState.autoInfTower = value
        if value then
            task.spawn(function()
                local maxDistance = 300
                while DungeonState.autoInfTower do
                    task.wait(0.01)
                    if isTeleportingInf then
                        task.wait(0.5)
                        continue
                    end
                    local character = LocalPlayer.Character
                    local hrp = getHumanoidRoot(character)
                    if not hrp then
                        continue
                    end
                    local enemiesToKill = {}
                    for _, obj in ipairs(LiveFolder:GetChildren()) do
                        if obj:IsA("Model") and obj ~= character then
                            local hum = obj:FindFirstChildOfClass("Humanoid")
                            local root = getHumanoidRoot(obj)
                            if hum and hum.Health > 0 and root then
                                local distance = (hrp.Position - root.Position).Magnitude
                                if distance <= maxDistance then
                                    table.insert(enemiesToKill, {
                                        model = obj,
                                        root = root,
                                        dist = distance
                                    })
                                end
                            end
                        end
                    end
                    if #enemiesToKill > 0 then
                        table.sort(enemiesToKill, function(a, b) return a.dist < b.dist end)
                        local target = enemiesToKill[1]
                        hrp.CFrame = target.root.CFrame * CFrame.new(0, 0, 2)
                        task.wait(0.05)
                        fireBladeCombat(false, target.root.Position, target.root.CFrame)
                        if FarmState.autoKillEnabled and target.model:FindFirstChildOfClass("Humanoid") then
                            target.model:FindFirstChildOfClass("Humanoid").Health = 0
                        end
                        task.wait(0.5)
                    else
                        local targetNPC = nil
                        local minNpcDist = math.huge
                        local floors = workspace:FindFirstChild("Floors")
                        if floors then
                            for _, floor in ipairs(floors:GetChildren()) do
                                local npc = floor:FindFirstChild("NPC")
                                if npc then
                                    local npcRoot = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildWhichIsA("BasePart")
                                    if npcRoot then
                                        local d = (hrp.Position - npcRoot.Position).Magnitude
                                        if d < minNpcDist then
                                            minNpcDist = d
                                            targetNPC = npc
                                        end
                                    end
                                end
                            end
                        end
                        if targetNPC then
                            local npcRoot = targetNPC:FindFirstChild("HumanoidRootPart") or targetNPC:FindFirstChildWhichIsA("BasePart")
                            local prompt = targetNPC:FindFirstChildOfClass("ProximityPrompt")
                            if npcRoot and not isTeleportingInf then
                                hrp.CFrame = npcRoot.CFrame * CFrame.new(0, 0, 3)
                                task.wait(0.2)
                                if prompt and prompt.Enabled then
                                    isTeleportingInf = true
                                    pcall(function()
                                        prompt.MaxActivationDistance = 999
                                        prompt.RequiresLineOfSight = false
                                        prompt:InputHoldBegin()
                                        task.wait(0.3)
                                        prompt:InputHoldEnd()
                                    end)
                                    task.wait(2.5)
                                    isTeleportingInf = false
                                end
                            end
                        end
                    end
                end
            end)
        end
    end,
})
