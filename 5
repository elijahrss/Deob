local function executeAutoBuyOnce()
    local BuyRemote = RemoteEvents:FindFirstChild("BuyItemRemote")
    local ClearRemote = RemoteEvents:FindFirstChild("ClearInventoryRemote")
    local storageRemote = RemoteEvents:FindFirstChild("StorageRemote")
    if buySettings.autoBuy and BuyRemote then
        for i = 1, buySettings.buyQuantity do
            safeFireRemote(BuyRemote, "BuyItemRemote", buySettings.itemName)
            task.wait(0.05)
        end
    end
    task.wait(0.3)
    local player = Players.LocalPlayer
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then
        return
    end
    local foundWhitelist = false
    local whitelistItems = {}
    for item in string.gmatch(buySettings.whitelist, '([^,]+)') do
        table.insert(whitelistItems, item:match("^%s*(.-)%s*$"))
    end
    for _, item in ipairs(backpack:GetChildren()) do
        local nameToCheck = item.Name
        if buySettings.bagCheck and item.Name == "Bag" then
            pcall(function()
                nameToCheck = item.BagPart.Overhead.ItemName.Text
            end)
        end
        if table.find(whitelistItems, nameToCheck) then
            foundWhitelist = true
            local values = player:FindFirstChild("PlayerValues")
            if storageRemote and values then
                for i = 1, 50 do
                    local slot = values:FindFirstChild("ItemStorage"..i)
                    if slot and slot.Value == "" then
                        safeFireRemote(storageRemote, "StorageRemote", item, slot.Name)
                        break
                    end
                end
            end
        end
    end
    if not foundWhitelist and buySettings.autoDelete and ClearRemote then
        safeFireRemote(ClearRemote, "ClearInventoryRemote")
    end
end
