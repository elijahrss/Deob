local function GetClosestLiveEnemy(maxDistance)
    local char = LocalPlayer.Character
    local root = getRoot(char)
    if not root then return nil end

    local mobsFolder = Workspace:FindFirstChild("Mobs")
    if not mobsFolder then return nil end

    local closest, minDistance = nil, maxDistance or math.huge

    for _, model in pairs(mobsFolder:GetChildren()) do
        if model:IsA("Model") then
            local targetRoot = model:FindFirstChild("HumanoidRootPart")
            local targetHumanoid = model:FindFirstChild("Humanoid")

            if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                local distance = (root.Position - targetRoot.Position).Magnitude
                
                if distance < minDistance then
                    minDistance = distance
                    closest = model
                end
            end
        end
    end
    return closest
end

local function GetWeaponCategory(weaponName)
    if string.find(weaponName, "Pickaxe") then return nil end

    local rep = game:GetService("ReplicatedStorage")
    
    local possibleFolders = {rep:FindFirstChild("Weapons"), rep:FindFirstChild("Tools"), rep:FindFirstChild("Assets")}
    
    for _, folder in pairs(possibleFolders) do
        if folder then
            for _, category in pairs(folder:GetChildren()) do
                if category:FindFirstChild(weaponName) then
                    return category.Name 
                end
            end
            if folder:FindFirstChild(weaponName) then
                return "Weapon" 
            end
        end
    end
    
    return "Unknown" 
end

