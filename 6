                    local tInfo = TweenInfo.new(time, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                    local tween = TweenService:Create(currentRoot, tInfo, {CFrame = CFrame.new(desiredPos)})
                    tween:Play()
                    RunService.Heartbeat:Wait()
                end
            else
                RunService.Heartbeat:Wait()
            end
        end
        
        cleanVelocity()
        bv:Destroy()
    end)
end

