-- Função para ler os ingredientes disponíveis na GUI
local function GetCookingIngredients()
    local ingredients = {}
    local seen = {}
    
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    local cookGui = pGui and pGui:FindFirstChild("CookingGui")
    
    -- Verifica se o inventário existe
    if cookGui and cookGui:FindFirstChild("Frame") and cookGui.Frame:FindFirstChild("Invy") then
        for _, itemFrame in pairs(cookGui.Frame.Invy:GetChildren()) do
            -- Ignora scripts ou layouts, foca nos botões/frames
            if itemFrame:IsA("ImageButton") or itemFrame:IsA("Frame") then
                local idObj = itemFrame:FindFirstChild("ItemID") -- O objeto que tem o nome
                local qtyObj = itemFrame:FindFirstChild("own")   -- O objeto que tem "x:123"
                
                if idObj and qtyObj then
                    -- Pega o nome (geralmente ItemID é um Value, mas previno se for string)
                    local name = idObj.Value 
                    
                    -- Se tiver nome, adiciona na lista
                    if name and name ~= "" then
                        if not seen[name] then
                            table.insert(ingredients, name)
                            seen[name] = true
                        end
                    end
                end
            end
        end
    end
    
    table.sort(ingredients)
    if #ingredients == 0 then table.insert(ingredients, "Abra a panela primeiro!") end
    return ingredients
end

-- Função para checar quantidade atual de um item específico (x:134 -> 134)
local function GetIngredientQuantity(itemName)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    local cookGui = pGui and pGui:FindFirstChild("CookingGui")
    
    if cookGui and cookGui.Frame and cookGui.Frame.Invy then
        for _, itemFrame in pairs(cookGui.Frame.Invy:GetChildren()) do
            local idObj = itemFrame:FindFirstChild("ItemID")
            local qtyObj = itemFrame:FindFirstChild("own")
            
            if idObj and idObj.Value == itemName and qtyObj then
                -- Limpeza da string: Pega "x:134" e transforma em "134"
                local rawText = qtyObj.ContentText or qtyObj.Text -- "x:134"
                local cleanText = string.gsub(rawText, "x:", "")  -- "134"
                return tonumber(cleanText) or 0
            end
        end
    end
    return 0
end

local function ToggleAutoEquip(bool)
    EquipState.Enabled = bool
    if EquipState.BackpackConnection then EquipState.BackpackConnection:Disconnect() EquipState.BackpackConnection = nil end
    if EquipState.CharConnection then EquipState.CharConnection:Disconnect() EquipState.CharConnection = nil end

    if bool then
        local bp = LocalPlayer:WaitForChild("Backpack", 5)
        if bp then
            EquipState.BackpackConnection = bp.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and child.Name == EquipState.SelectedTool and EquipState.Enabled then
                    task.wait() TryEquip()
                end
            end)
        end
        EquipState.CharConnection = LocalPlayer.CharacterAdded:Connect(function(newChar)
            local newBp = LocalPlayer:WaitForChild("Backpack", 10)
            if newBp and EquipState.Enabled then
                if EquipState.BackpackConnection then EquipState.BackpackConnection:Disconnect() end
                EquipState.BackpackConnection = newBp.ChildAdded:Connect(function(child)
                    if child:IsA("Tool") and child.Name == EquipState.SelectedTool and EquipState.Enabled then
                        task.wait() TryEquip()
                    end
                end)
                task.wait(1) TryEquip()
            end
        end)
        TryEquip()
    end
end

