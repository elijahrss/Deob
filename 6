                cleanVelocity()
                task.wait(0.5)
                continue
            end
            if oresFolder then
                for _, ore in pairs(oresFolder:GetChildren()) do
                    if ore:IsA("Model") then
                        local hp = ore:FindFirstChild("HP")
                    
                        if hp and hp:IsA("IntValue") and hp.Value > 0 then
                            local isMatch = false
                            
                            if mode == "all" then
                                isMatch = true
                            elseif mode == "selected" and MainState.selectedOreNames then
                                for _, selectedName in pairs(MainState.selectedOreNames) do
                                    if string.find(ore.Name, selectedName, 1, true) then
                                        isMatch = true
                                        break
                                    end
                                end
                            end

                            if isMatch then
                                local orePos = ore:GetPivot().Position
                                local dist = (orePos - myRoot.Position).Magnitude
                                if dist < minDist then
                                    minDist = dist
                                    target = {Model = ore, HP = hp}
                                end
                            end
                        end
                    end
                end
            end

            if target then
                if myRoot and not bv.Parent then bv.Parent = myRoot end
                
                local oreModel = target.Model
                local oreHP = target.HP
                while oreModel.Parent == oresFolder and oreHP.Value > 0 do
