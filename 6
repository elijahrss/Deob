local function runAutoCook()
    task.spawn(function()
        local RunService = game:GetService("RunService")
        
        while FarmState.autoCook do
            local itemName = FarmState.selectedFood
            
            -- 1. Validações Básicas
            if itemName == "" or itemName == "Abra a panela primeiro!" then
                Rayfield:Notify({Title = "Erro", Content = "Selecione um ingrediente!", Duration = 2})
                FarmState.autoCook = false
                break
            end

            -- 2. Verifica a quantidade (Se acabou, para)
            local qty = GetIngredientQuantity(itemName)
            if qty <= 0 then
                Rayfield:Notify({Title = "Auto Cook", Content = "Acabaram os ingredientes: " .. itemName, Duration = 3})
                FarmState.autoCook = false
                break
            end

            -- 3. Referências da GUI e Remote
            local pGui = LocalPlayer:FindFirstChild("PlayerGui")
            local cookGui = pGui and pGui:FindFirstChild("CookingGui")
            local parkourScript = pGui and pGui:FindFirstChild("Parkour") and pGui.Parkour:FindFirstChild("Script")
            
            if cookGui and parkourScript then
                local cookRemote = parkourScript:FindFirstChild("CookDish")
                local slot1 = cookGui:FindFirstChild("Frame") 
                              and cookGui.Frame:FindFirstChild("Cook") 
                              and cookGui.Frame.Cook:FindFirstChild("Slot1") 
                              and cookGui.Frame.Cook.Slot1:FindFirstChild("Item")

                -- 4. Renomeia o Slot (Simulação Visual/Lógica que você pediu)
                if slot1 then
                    slot1.Name = itemName
                end

                -- 5. Executa o Cozimento (ZERO DELAY)
                if cookRemote and workspace:FindFirstChild("CookingSpot") then
                    pcall(function()
                        -- InvokeServer pausa o script até o servidor responder.
                        -- Isso é o mais rápido possível. Se colocar loop sem wait aqui trava o PC.
                        cookRemote:InvokeServer(itemName, workspace.CookingSpot)
                    end)
                else
                    -- Se não achar o remote ou o spot, espera um frame pra não crashar
                    RunService.Heartbeat:Wait()
                end
            else
                 -- Se a GUI fechou, espera um pouco pra ver se abre
                RunService.Heartbeat:Wait()
            end
        end
    end)
end

local function runAutoFish()
    task.spawn(function()
        while FarmState.autoFish do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local spawnsFolder = workspace:FindFirstChild("FishingSpawns")

            if not root or not spawnsFolder then 
                task.wait(1) 
                continue 
            end
            local targetSpawn = nil
            local minDist = math.huge
            
            for _, spawnPart in pairs(spawnsFolder:GetChildren()) do
                local fishLeft = spawnPart:FindFirstChild("FishLeft")
                if fishLeft and fishLeft:IsA("IntValue") and fishLeft.Value > 0 then
                    local dist = (spawnPart.Position - root.Position).Magnitude
                    
                    if dist < minDist then
                        minDist = dist
                        targetSpawn = spawnPart
                    end
                end
            end
            if targetSpawn then
                local fishLeft = targetSpawn:FindFirstChild("FishLeft")
                local targetPos = targetSpawn.Position + Vector3.new(0, 3, 0)
                TweenTo(targetPos)
                while FarmState.autoFish and fishLeft and fishLeft.Value > 0 do
                    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
                    local catchRemote = pGui and pGui:FindFirstChild("Fish") 
                                      and pGui.Fish:FindFirstChild("Ado") 
                                      and pGui.Fish.Ado:FindFirstChild("catch")
                    
                    if catchRemote then
                        catchRemote:FireServer(targetSpawn)
                        task.wait(2.5) 
                    else
                        break 
                    end
                    if not root or (targetSpawn.Position - root.Position).Magnitude > 20 then
                        break
                    end
                end
            else
                task.wait(1)
            end
            
            task.wait(0.1)
        end
    end)
end

local CounterConnection = nil
local lastFireTime = 0

local function runAutoCounter(enabled)
    if CounterConnection then 
        CounterConnection:Disconnect() 
        CounterConnection = nil 
    end

    if enabled then
        CounterConnection = game:GetService("RunService").Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then return end

            local mobsFolder = workspace:FindFirstChild("Mobs")
            if not mobsFolder then return end

            local pGui = LocalPlayer:FindFirstChild("PlayerGui")
            local counterRemote = pGui and pGui:FindFirstChild("Parkour") 
                                  and pGui.Parkour:FindFirstChild("Script") 
                                  and pGui.Parkour.Script:FindFirstChild("Counter")
            
            if not counterRemote then return end

            local closestMob = nil
            local minDist = 50
            for _, mob in pairs(mobsFolder:GetChildren()) do
                local mobRoot = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso")
                if mobRoot then
                    local dist = (mobRoot.Position - root.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closestMob = mob
                    end
                end
            end
            if closestMob then
                local npc = closestMob:FindFirstChild("NPC")
                if npc then
                    local attacking = npc:FindFirstChild("attacking")
                    
                    if attacking and attacking:IsA("BoolValue") and attacking.Value == true then
                        if (tick() - lastFireTime) >= 0.08 then
                            counterRemote:FireServer()
                            lastFireTime = tick()
                        end
                    end
                end
            end
        end)
    end
end

local HitboxConnection = nil
local ProcessedMobs = {}

local function runHitboxExpander(enabled)
    if HitboxConnection then 
        HitboxConnection:Disconnect() 
        HitboxConnection = nil 
    end

    if not enabled then 
        ProcessedMobs = {} 
        return 
    end

    if enabled then
        HitboxConnection = game:GetService("RunService").Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local myRoot = char and char:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end

            local mobsFolder = Workspace:FindFirstChild("Mobs")
            if not mobsFolder then return end
            local size = FarmState.hitboxSize or 20
            local triggerDistance = 20
            for _, mob in pairs(mobsFolder:GetChildren()) do
                if not ProcessedMobs[mob] then
                    local mobRoot = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso")
                    if mobRoot then
                        local dist = (mobRoot.Position - myRoot.Position).Magnitude
                        if dist <= triggerDistance then
                            pcall(function()
                                mobRoot.Size = Vector3.new(size, size, size)
                                mobRoot.Transparency = 1
                                mobRoot.BrickColor = BrickColor.new("Really blue")
                                mobRoot.Material = Enum.Material.Neon
                                mobRoot.CanCollide = false
                            end)
                            ProcessedMobs[mob] = true
                        end
                    end
                end
            end
        end)
    end
end

