local function performSell()
    local dataFolder = LocalPlayer:FindFirstChild("Data")
    if not dataFolder then return end
    
    if #ShopState.sellSelectedItems == 0 then return end

    local desiredAmount = ShopState.sellQuantity or 1

    for _, itemName in pairs(ShopState.sellSelectedItems) do
        if itemName == "No Items Found" or itemName == "Waiting for Inventory..." then continue end

        local dataValue = dataFolder:FindFirstChild(itemName)
        
        if dataValue and dataValue:IsA("IntValue") and dataValue.Value > 0 then
            local currentStock = dataValue.Value
            
            if desiredAmount >= currentStock then
                pcall(function()
                    ReplicatedStorage.Remotes.SellItem:FireServer(itemName, "Sell", true)
                end)
                Rayfield:Notify({Title = "Venda Rápida", Content = "Vendido todo o estoque de " .. itemName, Duration = 2})
            else
                task.spawn(function()
                    Rayfield:Notify({Title = "Venda Parcial", Content = "Vendendo " .. desiredAmount .. "x " .. itemName .. "...", Duration = 2})
                    
                    for i = 1, desiredAmount do
                        pcall(function()
                            ReplicatedStorage.Remotes.SellItem:FireServer(itemName, "Sell", false)
                        end)
                        
                        if i % 50 == 0 then task.wait() end
                    end
                    
                    Rayfield:Notify({Title = "Concluído", Content = "Venda parcial finalizada", Duration = 2})
                end)
            end
        end
    end
end

