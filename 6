TradeTab:CreateButton({
    Name = "Force trade(Random)",
    Callback = function()
        local playersList = Players:GetPlayers()
        if #playersList < 2 then return end
        local t1 = playersList[math.random(1, #playersList)]
        local t2 = playersList[math.random(1, #playersList)]
        if t1 == t2 then t2 = playersList[math.random(1, #playersList)] end
        ReplicatedStorage.Remotes.AddTradeFrame:FireServer(t1, t2)
    end,
})
