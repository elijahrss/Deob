local function getClosestMobRexl(range)
    local char = game:GetService("Players").LocalPlayer.Character
    local root = getRootLocal(char)
    if not root then return nil end

    local mobsFolder = workspace:FindFirstChild("Mobs")
    if not mobsFolder then return nil end

    local closest, minDist = nil, range or 500

    for _, mob in pairs(mobsFolder:GetChildren()) do
        if mob:IsA("Model") then
            local hum = mob:FindFirstChild("Humanoid")
            local pivot = mob:GetPivot()
            local mobPos = pivot and pivot.Position
            
            if not mobPos and mob:FindFirstChild("HumanoidRootPart") then
                mobPos = mob.HumanoidRootPart.Position
            end

            if hum and hum.Health > 0 and mobPos then
                local dist = (root.Position - mobPos).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = mob
                end
            end
        end
    end
    return closest
end

local function TweenSafe(targetPos)
    local char = game:GetService("Players").LocalPlayer.Character
    local root = getRootLocal(char)
    if not root then return end
    
    local dist = (targetPos - root.Position).Magnitude
    
    local speed = FarmState.tweenSpeed or 300
    local time = math.max(dist / speed, 0.15) 
    
    local tInfo = TweenInfo.new(time, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = game:GetService("TweenService"):Create(root, tInfo, {CFrame = CFrame.new(targetPos)})
    
    tween:Play()
    tween.Completed:Wait()
end

local function runFarmNearest()
    task.spawn(function()
        local TweenService = game:GetService("TweenService")
        local RunService = game:GetService("RunService")
        local Players = game:GetService("Players")
        local DirectionOffsets = {
            Above = Vector3.new(0, 1, 0),
            Below = Vector3.new(0, -1, 0),
            Behind = Vector3.new(0, 0, 1)
        }
        local function getRootSafe()
            local char = Players.LocalPlayer.Character
            return char and char:FindFirstChild("HumanoidRootPart")
        end
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FarmAntiGravity_Nearest"
        bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = 10000
        local function cleanVelocity()
            if bv.Parent then bv.Parent = nil end
        end
        while FarmState.farmNearest do
            local mobsFolder = Workspace:FindFirstChild("Mobs")
            local targetMob = nil
            local targetPart = nil
            local minDist = math.huge 
            local myRoot = getRootSafe()
            if not myRoot then
                cleanVelocity()
                task.wait(0.5)
                continue
            end
            if mobsFolder then
                for _, mob in pairs(mobsFolder:GetChildren()) do
                    if mob:IsA("Model") then
                        local hrp = mob:FindFirstChild("HumanoidRootPart")
                        local hum = mob:FindFirstChild("Humanoid")
                        if hrp and hum and hum.Health > 0 then
                            local dist = (hrp.Position - myRoot.Position).Magnitude
                            if dist < minDist then
                                minDist = dist
                                targetMob = mob
                                targetPart = hrp
                            end
                        end
                    end
                end
            end
            if targetMob and targetPart then
                if myRoot and not bv.Parent then bv.Parent = myRoot end
                while FarmState.farmNearest and targetMob.Parent and targetPart.Parent do
                    local currentRoot = getRootSafe()
                    if not currentRoot then break end
                    if bv.Parent ~= currentRoot then bv.Parent = currentRoot end
                    local hum = targetMob:FindFirstChild("Humanoid")
                    if hum and hum.Health <= 0 then break end
                    local mobCFrame = targetPart.CFrame
                    local dirName = FarmState.farmAngle or "Above"
                    local directionVec = DirectionOffsets[dirName] or DirectionOffsets.Above
                    local finalOffset = directionVec * (FarmState.farmDistance or 5)
                    local desiredPos = (mobCFrame * CFrame.new(finalOffset)).Position
                    local dist = (desiredPos - currentRoot.Position).Magnitude
                    local speed = FarmState.tweenSpeed or 300
