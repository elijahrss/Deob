            MainState.farmSelectedOre = false
            return
        end

        while (mode == "all" and MainState.farmAllOres) or (mode == "selected" and MainState.farmSelectedOre) do
            local oresFolder = Workspace:FindFirstChild("Ores")
            local target = nil
            local minDist = math.huge
            local myChar = Players.LocalPlayer.Character
