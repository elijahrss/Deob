    local dataFolder = LocalPlayer:WaitForChild("Data", 10)
    if dataFolder then
        table.insert(InventoryConnections, dataFolder.ChildAdded:Connect(function()
            updateInventoryUI()
        end))
        table.insert(InventoryConnections, dataFolder.ChildRemoved:Connect(function()
            updateInventoryUI()
        end))
        updateInventoryUI()
    end
end

