local function TweenTo(targetPosition)
    local char = getCharacter()
    local root = getRoot(char)
    if not root then return end
    
    local distance = (targetPosition - root.Position).Magnitude
    local time = distance / FarmState.tweenSpeed
    
    local tInfo = TweenInfo.new(time, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tween = TweenService:Create(root, tInfo, {CFrame = CFrame.new(targetPosition)})
    
    tween:Play()
    tween.Completed:Wait()
end

