local function runDropFarm()
    task.spawn(function()
        local TweenService = game:GetService("TweenService")
        local RunService = game:GetService("RunService")
        local Players = game:GetService("Players")

        local bv = Instance.new("BodyVelocity")
        bv.Name = "DropFarmAntiGravity"
        bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = 10000

        local function cleanVelocity()
            if bv.Parent then bv.Parent = nil end
        end

        while FarmState.dropsActive do
            local dropsFolder = Workspace:FindFirstChild("Drops")
            local target = nil
            local minDist = math.huge
            local myChar = Players.LocalPlayer.Character
            local myRoot = getRoot(myChar)

            if not myRoot then
                cleanVelocity()
                task.wait(0.5)
                continue
            end

            if dropsFolder then
                for _, drop in pairs(dropsFolder:GetChildren()) do
                    local actualItem = drop:FindFirstChild(drop.Name) or drop:FindFirstChild("CursedFinger") or drop:FindFirstChild("Drop") or drop
                    local targetPos = nil

                    if actualItem:IsA("Model") then
                        targetPos = actualItem:GetPivot().Position
                    elseif actualItem:IsA("BasePart") then
                        targetPos = actualItem.Position
                    end

                    if targetPos then
                        local dist = (targetPos - myRoot.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            target = {Object = drop, Position = targetPos}
                        end
                    end
                end
            end

            if target then
                if myRoot and not bv.Parent then bv.Parent = myRoot end
                
                local dropObj = target.Object

                while FarmState.dropsActive and dropObj and dropObj.Parent do
                    if not Players.LocalPlayer.Character then break end
                    local currentRoot = Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if not currentRoot then break end
                    
                    if bv.Parent ~= currentRoot then bv.Parent = currentRoot end

                    local actualItem = dropObj:FindFirstChild(dropObj.Name) or dropObj:FindFirstChild("CursedFinger") or dropObj:FindFirstChild("Drop") or dropObj
                    local destPos = nil
                    
                    if actualItem:IsA("Model") then destPos = actualItem:GetPivot().Position
                    elseif actualItem:IsA("BasePart") then destPos = actualItem.Position end
                    
                    if not destPos then break end 

                    local dist = (destPos - currentRoot.Position).Magnitude
                    local speed = FarmState.tweenSpeed or 300

                    local time = math.max(dist / speed, 0.05)
                    local tInfo = TweenInfo.new(time, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                    local tween = TweenService:Create(currentRoot, tInfo, {CFrame = CFrame.new(destPos)})
                    tween:Play()

                    if dist < 10 then
                        collectDrop(dropObj)
                        
                        local touchPart = dropObj:FindFirstChild("Touched")
                        if touchPart and touchPart:FindFirstChild("TouchInterest") then
                           firetouchinterest(currentRoot, touchPart, 0)
                           firetouchinterest(currentRoot, touchPart, 1)
                        end
                    end

                    RunService.Heartbeat:Wait()
                end
            else
                RunService.Heartbeat:Wait()
            end
        end

        cleanVelocity()
        bv:Destroy()
    end)
end

