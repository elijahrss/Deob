local function TryEquip()
    if not EquipState.Enabled or EquipState.SelectedTool == "" or EquipState.SelectedTool == "Nenhuma Tool Encontrada" then return end
    
    local LocalPlayer = game:GetService("Players").LocalPlayer
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local hum = char and char:FindFirstChild("Humanoid")

    if char and backpack and hum and hum.Health > 0 then
        local tool = backpack:FindFirstChild(EquipState.SelectedTool)
        if tool then
            hum:EquipTool(tool)
            task.delay(0.1, function()
                if tool.Parent == char then
                    for _, desc in pairs(tool:GetDescendants()) do
                        if desc:IsA("RemoteEvent") and (string.find(desc.Name, "Equip") or string.find(desc.Name, "Activate")) then
                            pcall(function() desc:FireServer() end)
                        end
                    end
                end
            end)
        end
    end
end

