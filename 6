                                break
                            end
                        end

                        if isSelected then
                            local foundCollectable = getActiveCollectable(plant)
                            if foundCollectable then
                                local pivot = plant:GetPivot()
                                if pivot then
                                    local dist = (pivot.Position - myRoot.Position).Magnitude
                                    
                                    if dist < minDist then
                                        minDist = dist
                                        targetPlant = plant
                                        targetCollectable = foundCollectable
                                    end
                                end
                            end
                        end
                    end
                end
            end
            if targetPlant and targetCollectable then
                if myRoot and not bv.Parent then bv.Parent = myRoot end
                while PlantState.autoPlant and targetPlant.Parent and targetCollectable.Value == true do
                    local currentRoot = getRootSafe()
                    if not currentRoot then break end
                    if bv.Parent ~= currentRoot then bv.Parent = currentRoot end
                    local destPos = targetPlant:GetPivot().Position
                    local dist = (destPos - currentRoot.Position).Magnitude
                    local speed = FarmState.tweenSpeed or 300
                    local time = math.max(dist / speed, 0.05)
                    local tInfo = TweenInfo.new(time, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                    local tween = TweenService:Create(currentRoot, tInfo, {CFrame = CFrame.new(destPos)})
                    tween:Play()
                    if dist < 12 then
                        for _, desc in pairs(targetPlant:GetDescendants()) do
